        "# ==========================\n",
        "# 1. โหลดขอบเขตอำเภอสอง จังหวัดแพร่\n",
        "# ==========================\n",
        "districts = ee.FeatureCollection(\"FAO/GAUL/2015/level2\")\n",
        "\n",
        "roi = districts \\\n",
        "    .filter(ee.Filter.eq('ADM0_NAME','Thailand')) \\\n",
        "    .filter(ee.Filter.eq('ADM1_NAME','Phrae')) \\\n",
        "    .filter(ee.Filter.eq('ADM2_NAME','Song'))  # อำเภอสอง\n",
        "\n",
        "# ==========================\n",
        "# 2. สร้างแผนที่\n",
        "# ==========================\n",
        "Map = geemap.Map(center=[18.2, 100.2], zoom=11)\n",
        "Map.addLayer(roi, {'color':'red'}, 'Song District')\n",
        "\n",
        "# ==========================\n",
        "# 3. โหลดข้อมูล Sentinel-2\n",
        "# ==========================\n",
        "s2 = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2023-11-01','2024-04-30') \\\n",
        "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE',20)) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "# ==========================\n",
        "# 4. คำนวณ NDVI\n",
        "# ==========================\n",
        "ndvi = s2.normalizedDifference(['B8','B4']).rename('NDVI')\n",
        "\n",
        "Map.addLayer(ndvi, {\n",
        "    'min': 0,\n",
        "    'max': 1,\n",
        "    'palette': ['red', 'yellow', 'green']\n",
        "}, 'NDVI')\n",
        "\n",
        "# Zonal statistics NDVI\n",
        "stats = ndvi.reduceRegion(\n",
        "    reducer=ee.Reducer.mean(),\n",
        "    geometry=roi,\n",
        "    scale=10,\n",
        "    maxPixels=1e9\n",
        ")\n",
        "print('Mean NDVI in Song District:', stats.getInfo())\n",
        "\n",
        "# ==========================\n",
        "# 5. คำนวณ MNDWI\n",
        "# ==========================\n",
        "mndwi = s2.normalizedDifference(['B3', 'B11']).rename('MNDWI')\n",
        "\n",
        "Map.addLayer(mndwi, {\n",
        "    'min': -1,\n",
        "    'max': 1,\n",
        "    'palette': ['brown','yellow','blue']\n",
        "}, 'MNDWI')\n",
        "\n",
        "# Zonal statistics MNDWI\n",
        "stats_mndwi = mndwi.reduceRegion(\n",
        "    reducer=ee.Reducer.mean(),\n",
        "    geometry=roi,\n",
        "    scale=10,\n",
        "    maxPixels=1e9\n",
        ")\n",
        "print('Mean MNDWI in Song District:', stats_mndwi.getInfo())\n",
        "\n",
        "# ==========================\n",
        "# 6. คำนวณ NDMI (ความชื้นในพืช/ดิน)\n",
        "# ==========================\n",
        "ndmi = s2.normalizedDifference(['B8','B11']).rename('NDMI')\n",
        "\n",
        "Map.addLayer(ndmi, {\n",
        "    'min': -1,\n",
        "    'max': 1,\n",
        "    'palette': ['brown','yellow','blue']\n",
        "}, 'NDMI')\n",
        "\n",
        "# Zonal statistics NDMI\n",
        "stats_ndmi = ndmi.reduceRegion(\n",
        "    reducer=ee.Reducer.mean(),\n",
        "    geometry=roi,\n",
        "    scale=10,\n",
        "    maxPixels=1e9\n",
        ")\n",
        "print('Mean NDMI in Song District:', stats_ndmi.getInfo())\n",
        "\n",
        "# ==========================\n",
        "# 7. Classification (NDVI + MNDWI + NDMI)\n",
        "# ==========================\n",
        "# NDVI > 0.3 = พืช\n",
        "# MNDWI > 0 = น้ำ\n",
        "# NDMI > 0.2 = ชื้น\n",
        "\n",
        "dry = ndvi.lt(0.2) \\\n",
        "    .And(mndwi.lt(-0.1)) \\\n",
        "    .And(ndmi.lt(0.1))\n",
        "veg = ndvi.gt(0.2)\n",
        "water = mndwi.gt(0)\n",
        "wetveg = ndvi.gt(0.3).And(ndmi.gt(0.2))\n",
        "\n",
        "combined_new = dry.multiply(0) \\\n",
        "    .add(veg.multiply(1)) \\\n",
        "    .add(water.multiply(2)) \\\n",
        "    .add(wetveg.multiply(3))\n",
        "\n",
        "Map.addLayer(combined_new, {\n",
        "    'min': 0,\n",
        "    'max': 3,\n",
        "    'palette': [\n",
        "        'brown',   # แห้ง\n",
        "        'green',   # พืช\n",
        "        'blue',    # น้ำ\n",
        "        'cyan'     # พืชชื้น\n",
        "    ]\n",
        "}, 'Combined Class')\n",
        "\n",
