        "# เปรียบเทียบความแตกต่าง การเปลี่ยนแปลงของindex ระหว่างสองช่วงเวลา"
      ],
      "metadata": {
        "id": "LFUL9Gg09z7M"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================\n",
        "# 1.ขอบเขตอำเภอสอง, แพร่\n",
        "# ==========================\n",
        "districts = ee.FeatureCollection(\"FAO/GAUL/2015/level2\")\n",
        "roi = districts \\\n",
        "    .filter(ee.Filter.eq('ADM0_NAME','Thailand')) \\\n",
        "    .filter(ee.Filter.eq('ADM1_NAME','Phrae')) \\\n",
        "    .filter(ee.Filter.eq('ADM2_NAME','Song'))\n",
        "\n",
        "Map = geemap.Map(center=[18.2, 100.2], zoom=11)\n",
        "\n",
        "# ==========================\n",
        "# 2. ฤดูแล้ง (พย - เม.ย 2024)\n",
        "# ==========================\n",
        "s2_dry = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2023-11-01','2024-04-30') \\\n",
        "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE',20)) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "ndvi_dry = s2_dry.normalizedDifference(['B8','B4']).rename('NDVI_dry')\n",
        "mndwi_dry = s2_dry.normalizedDifference(['B3','B11']).rename('MNDWI_dry')\n",
        "\n",
        "# ==========================\n",
        "# 3. นอกฤดูแล้ง / ฤดูฝน ( พค – ต.ค. 2024)\n",
        "# ==========================\n",
        "s2_wet = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2024-05-20','2024-10-30') \\\n",
        "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE',50)) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "ndvi_wet = s2_wet.normalizedDifference(['B8','B4']).rename('NDVI_wet')\n",
        "mndwi_wet = s2_wet.normalizedDifference(['B3','B11']).rename('MNDWI_wet')\n",
        "\n",
        "# ==========================\n",
        "# 4. Difference (ฤดูฝน - ฤดูแล้ง)\n",
        "# ==========================\n",
        "ndvi_diff = ndvi_wet.subtract(ndvi_dry).rename('NDVI_diff')\n",
        "mndwi_diff = mndwi_wet.subtract(mndwi_dry).rename('MNDWI_diff')\n",
        "\n",
        "# ==========================\n",
        "# 5. แสดงผลบน Map\n",
        "# ==========================\n",
        "# NDVI\n",
        "Map.addLayer(ndvi_dry, {'min':0,'max':1,'palette':['red','yellow','green']}, 'NDVI Dry Season')\n",
        "Map.addLayer(ndvi_wet, {'min':0,'max':1,'palette':['red','yellow','green']}, 'NDVI Wet Season')\n",
        "\n",
        "# NDVI Change\n",
        "Map.addLayer(ndvi_diff, {'min':-0.5,'max':0.7,'palette':['brown','yellow','green']}, 'NDVI Change (Wet - Dry)')\n",
        "\n",
        "# MNDWI\n",
        "Map.addLayer(mndwi_dry, {'min':-1,'max':1,'palette':['brown','yellow','blue']}, 'MNDWI Dry Season')\n",
        "Map.addLayer(mndwi_wet, {'min':-1,'max':1,'palette':['brown','yellow','blue']}, 'MNDWI Wet Season')\n",
        "\n",
        "# MNDWI Change\n",
        "Map.addLayer(mndwi_diff, {'min':-0.5,'max':0.7,'palette':['brown','white','blue']}, 'MNDWI Change (Wet - Dry)')\n",
        "\n",
        "# ==========================\n",
        "# 6. NDMI (เพิ่มใหม่)\n",
        "# ==========================\n",
        "ndmi_dry = s2_dry.normalizedDifference(['B8','B11']).rename('NDMI_dry')\n",
        "ndmi_wet = s2_wet.normalizedDifference(['B8','B11']).rename('NDMI_wet')\n",
        "\n",
        "# Difference\n",
        "ndmi_diff = ndmi_wet.subtract(ndmi_dry).rename('NDMI_diff')\n",
        "\n",
        "# ==========================\n",
        "# 7. แสดงผล NDMI\n",
        "# ==========================\n",
        "Map.addLayer(ndmi_dry, {'min':-1,'max':1,'palette':['brown','yellow','blue']}, 'NDMI Dry Season')\n",
        "Map.addLayer(ndmi_wet, {'min':-1,'max':1,'palette':['brown','yellow','blue']}, 'NDMI Wet Season')\n",
        "\n",
        "Map.addLayer(ndmi_diff, {'min':-0.5,'max':0.7,'palette':['brown','white','blue']}, 'NDMI Change (Wet - Dry)')\n",
        "\n",
        "Map.addLayerControl()\n",
        "Map"
      ],
