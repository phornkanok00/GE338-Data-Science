    {
      "cell_type": "code",
      "source": [
        "import ee\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "\n",
        "# ==========================\n",
        "# 1. ROI (อำเภอสอง)\n",
        "# ==========================\n",
        "districts = ee.FeatureCollection(\"FAO/GAUL/2015/level2\")\n",
        "\n",
        "roi = districts \\\n",
        "    .filter(ee.Filter.eq('ADM0_NAME','Thailand')) \\\n",
        "    .filter(ee.Filter.eq('ADM1_NAME','Phrae')) \\\n",
        "    .filter(ee.Filter.eq('ADM2_NAME','Song'))\n",
        "\n",
        "# ==========================\n",
        "# 2. Sentinel-2\n",
        "# ==========================\n",
        "s2 = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2023-11-01','2024-04-30') \\\n",
        "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE',20)) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "# ==========================\n",
        "# 3. NDVI + MNDWI\n",
        "# ==========================\n",
        "ndvi = s2.normalizedDifference(['B8','B4']).rename('NDVI')\n",
        "mndwi = s2.normalizedDifference(['B3','B11']).rename('MNDWI')\n",
        "\n",
        "stack = ndvi.addBands(mndwi)\n",
        "\n",
        "# ==========================\n",
        "# 4. สุ่มจุด (กันพัง)\n",
        "# ==========================\n",
        "points = ee.FeatureCollection.randomPoints(\n",
        "    region=roi.geometry(),\n",
        "    points=200,\n",
        "    seed=42\n",
        ")\n",
        "\n",
        "sample = stack.sampleRegions(\n",
        "    collection=points,\n",
        "    scale=30\n",
        ")\n",
        "\n",
        "# ==========================\n",
        "# 5. Correlation\n",
        "# ==========================\n",
        "corr = sample.reduceColumns(\n",
        "    reducer=ee.Reducer.pearsonsCorrelation(),\n",
        "    selectors=['NDVI','MNDWI']\n",
        ")\n",
        "\n",
        "print('Correlation NDVI vs MNDWI:', corr.getInfo())\n",
        "\n",
        "# ==========================\n",
        "# 6. แปลงข้อมูล (ไม่ใช้ geemap)\n",
        "# ==========================\n",
        "data = sample.getInfo()['features']\n",
        "\n",
        "ndvi_list = []\n",
        "mndwi_list = []\n",
        "\n",
        "for f in data:\n",
        "    ndvi_list.append(f['properties']['NDVI'])\n",
        "    mndwi_list.append(f['properties']['MNDWI'])\n",
        "\n",
        "# ==========================\n",
        "# 7. Scatter Plot + Regression\n",
        "# ==========================\n",
        "z = np.polyfit(ndvi_list, mndwi_list, 1)\n",
        "p = np.poly1d(z)\n",
        "\n",
        "plt.figure()\n",
        "plt.scatter(ndvi_list, mndwi_list, s=10)\n",
        "plt.plot(ndvi_list, p(ndvi_list), color='black')\n",
        "plt.xlabel('NDVI')\n",
        "plt.ylabel('MNDWI')\n",
        "plt.title('NDVI vs MNDWI Correlation')\n",
        "plt.show()"
      ],
