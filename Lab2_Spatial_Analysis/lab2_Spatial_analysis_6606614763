      "cell_type": "markdown",
      "source": [
        "# เปรียบเทียบความแตกต่าง การเปลี่ยนแปลงของindex ระหว่างสองช่วงเวลา"
      ],
      "metadata": {
        "id": "LFUL9Gg09z7M"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import ee\n",
        "import geemap\n",
        "\n",
        "# ==========================\n",
        "# 1. ฟังก์ชันช่วย (Helper Functions)\n",
        "# ==========================\n",
        "def mask_s2_clouds(image):\n",
        "    \"\"\"ฟังก์ชันลบเมฆโดยใช้ QA60 Band\"\"\"\n",
        "    qa = image.select('QA60')\n",
        "    cloud_bit_mask = 1 << 10\n",
        "    cirrus_bit_mask = 1 << 11\n",
        "    mask = qa.bitwiseAnd(cloud_bit_mask).eq(0).And(\n",
        "             qa.bitwiseAnd(cirrus_bit_mask).eq(0))\n",
        "    return image.updateMask(mask).divide(10000) # Scale Factor ให้ค่าอยู่ระหว่าง 0-1\n",
        "\n",
        "# ==========================\n",
        "# 2. ขอบเขตอำเภอสอง, แพร่\n",
        "# ==========================\n",
        "districts = ee.FeatureCollection(\"FAO/GAUL/2015/level2\")\n",
        "roi = districts \\\n",
        "    .filter(ee.Filter.eq('ADM0_NAME','Thailand')) \\\n",
        "    .filter(ee.Filter.eq('ADM1_NAME','Phrae')) \\\n",
        "    .filter(ee.Filter.eq('ADM2_NAME','Song'))\n",
        "\n",
        "Map = geemap.Map(center=[18.4, 100.2], zoom=10)\n",
        "\n",
        "# ==========================\n",
        "# 3. ประมวลผลข้อมูล (Dry vs Wet)\n",
        "# ==========================\n",
        "# ฤดูแล้ง: เน้นภาพที่ใส (Cloud < 20) และ Mask เมฆซ้ำ\n",
        "s2_dry = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2023-11-01','2024-04-30') \\\n",
        "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20)) \\\n",
        "    .map(mask_s2_clouds) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "# ฤดูฝน: ปรับ Filter เป็น 80% แต่ใช้ฟังก์ชัน Mask รายพิกเซลช่วย\n",
        "# เพื่อดึงข้อมูลส่วนที่ไม่มีเมฆจากทุกภาพมาใช้ (แก้ปัญหาภาพหาย)\n",
        "s2_wet = ee.ImageCollection(\"COPERNICUS/S2_SR_HARMONIZED\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2024-05-20','2024-10-30') \\\n",
        "    .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 80)) \\\n",
        "    .map(mask_s2_clouds) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "# ==========================\n",
        "# 4. คำนวณดัชนี (Indices)\n",
        "# ==========================\n",
        "# NDVI (พืชพรรณ)\n",
        "ndvi_dry = s2_dry.normalizedDifference(['B8','B4']).rename('NDVI_dry')\n",
        "ndvi_wet = s2_wet.normalizedDifference(['B8','B4']).rename('NDVI_wet')\n",
        "ndvi_diff = ndvi_wet.subtract(ndvi_dry).rename('NDVI_diff')\n",
        "\n",
        "# MNDWI (น้ำ/ความชื้นผิวดิน)\n",
        "mndwi_dry = s2_dry.normalizedDifference(['B3','B11']).rename('MNDWI_dry')\n",
        "mndwi_wet = s2_wet.normalizedDifference(['B3','B11']).rename('MNDWI_wet')\n",
        "mndwi_diff = mndwi_wet.subtract(mndwi_dry).rename('MNDWI_diff')\n",
        "\n",
        "# NDMI (ความชื้นในใบพืช)\n",
        "ndmi_dry = s2_dry.normalizedDifference(['B8','B11']).rename('NDMI_dry')\n",
        "ndmi_wet = s2_wet.normalizedDifference(['B8','B11']).rename('NDMI_wet')\n",
        "ndmi_diff = ndmi_wet.subtract(ndmi_dry).rename('NDMI_diff')\n",
        "\n",
        "# ==========================\n",
        "# 5. แสดงผลบน Map\n",
        "# ==========================\n",
        "# NDVI Visual\n",
        "Map.addLayer(ndvi_dry, {'min':0,'max':0.8,'palette':['red','yellow','green']}, 'NDVI Dry (Nov-Apr)')\n",
        "Map.addLayer(ndvi_wet, {'min':0,'max':0.8,'palette':['red','yellow','green']}, 'NDVI Wet (May-Oct)')\n",
        "Map.addLayer(ndvi_diff, {'min':-0.3,'max':0.3,'palette':['brown','yellow','green']}, 'NDVI Diff (Wet - Dry)')\n",
        "\n",
        "# MNDWI Visual (เน้นดูน้ำ/ความชื้น)\n",
        "Map.addLayer(mndwi_dry, {'min':-0.5,'max':0.5,'palette':['brown','yellow','blue']}, 'MNDWI Dry')\n",
        "Map.addLayer(mndwi_wet, {'min':-0.5,'max':0.5,'palette':['brown','yellow','blue']}, 'MNDWI Wet')\n",
        "\n",
        "# NDMI Visual (ความชื้นพืช)\n",
        "Map.addLayer(ndmi_dry, {'min':-0.2,'max':0.4,'palette':['#d73027','#f4a582','#f7f7f7','#92c5de','#0571b0']}, 'NDMI Dry (Moisture)')\n",
        "Map.addLayer(ndmi_wet, {'min':-0.2,'max':0.4,'palette':['#d73027','#f4a582','#f7f7f7','#92c5de','#0571b0']}, 'NDMI Wet (Moisture)')\n",
        "Map.addLayer(ndmi_diff, {'min':-0.2,'max':0.2,'palette':['red','white','blue']}, 'NDMI Change')\n",
        "\n",
        "Map.addLayerControl()\n",
        "Map\n"
      ],
