      "source": [
        "# ทดสอบการใช้ดาวเทียมตัวอื่น (Landsat 8)"
      ],
      "metadata": {
        "id": "C9TgVMTfSV1C"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import ee\n",
        "import geemap\n",
        "\n",
        "# ==========================\n",
        "# 1. ฟังก์ชันช่วย (Landsat Cloud Mask & Scale)\n",
        "# ==========================\n",
        "def mask_ls_clouds(image):\n",
        "    \"\"\"ฟังก์ชันลบเมฆสำหรับ Landsat 8/9 C2 L2\"\"\"\n",
        "    # Bitmask สำหรับเมฆและเงาเมฆ\n",
        "    qa = image.select('QA_PIXEL')\n",
        "    dilated_cloud = 1 << 1\n",
        "    cirrus = 1 << 2\n",
        "    cloud = 1 << 3\n",
        "    cloud_shadow = 1 << 4\n",
        "\n",
        "    mask = qa.bitwiseAnd(dilated_cloud).eq(0) \\\n",
        "             .And(qa.bitwiseAnd(cirrus).eq(0)) \\\n",
        "             .And(qa.bitwiseAnd(cloud).eq(0)) \\\n",
        "             .And(qa.bitwiseAnd(cloud_shadow).eq(0))\n",
        "\n",
        "    # Landsat C2 L2 ต้องใช้ Scale Factor (0.0000275 + -0.2)\n",
        "    optical_bands = image.select('SR_B.').multiply(0.0000275).add(-0.2)\n",
        "    return image.addBands(optical_bands, None, True).updateMask(mask)\n",
        "\n",
        "# ==========================\n",
        "# 2. ขอบเขตอำเภอสอง, แพร่\n",
        "# ==========================\n",
        "districts = ee.FeatureCollection(\"FAO/GAUL/2015/level2\")\n",
        "roi = districts \\\n",
        "    .filter(ee.Filter.eq('ADM0_NAME','Thailand')) \\\n",
        "    .filter(ee.Filter.eq('ADM1_NAME','Phrae')) \\\n",
        "    .filter(ee.Filter.eq('ADM2_NAME','Song'))\n",
        "\n",
        "Map = geemap.Map(center=[18.4, 100.2], zoom=10)\n",
        "\n",
        "# ==========================\n",
        "# 3. ประมวลผลข้อมูล Landsat 8/9 (Dry vs Wet)\n",
        "# ==========================\n",
        "# ฤดูแล้ง\n",
        "ls_dry = ee.ImageCollection(\"LANDSAT/LC08/C02/T1_L2\") \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2023-11-01','2024-04-30') \\\n",
        "    .map(mask_ls_clouds) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "# ฤดูฝน (เพิ่มความยืดหยุ่นเรื่องเมฆเหมือนเดิม)\n",
        "ls_wet = ee.ImageCollection(\"LANDSAT/LC08/C02/T1_L2\") \\\n",
        "    .merge(ee.ImageCollection(\"LANDSAT/LC09/C02/T1_L2\")) \\\n",
        "    .filterBounds(roi) \\\n",
        "    .filterDate('2024-05-20','2024-10-30') \\\n",
        "    .map(mask_ls_clouds) \\\n",
        "    .median() \\\n",
        "    .clip(roi)\n",
        "\n",
        "# ==========================\n",
        "# 4. คำนวณดัชนี (Bands ของ Landsat 8/9: NIR=B5, Red=B4, Green=B3, SWIR1=B6)\n",
        "# ==========================\n",
        "# NDVI\n",
        "ndvi_dry = ls_dry.normalizedDifference(['SR_B5','SR_B4']).rename('NDVI_dry')\n",
        "ndvi_wet = ls_wet.normalizedDifference(['SR_B5','SR_B4']).rename('NDVI_wet')\n",
        "ndvi_diff = ndvi_wet.subtract(ndvi_dry).rename('NDVI_diff')\n",
        "\n",
        "# MNDWI (Green & SWIR1)\n",
        "mndwi_dry = ls_dry.normalizedDifference(['SR_B3','SR_B6']).rename('MNDWI_dry')\n",
        "mndwi_wet = ls_wet.normalizedDifference(['SR_B3','SR_B6']).rename('MNDWI_wet')\n",
        "\n",
        "# NDMI (NIR & SWIR1)\n",
        "ndmi_dry = ls_dry.normalizedDifference(['SR_B5','SR_B6']).rename('NDMI_dry')\n",
        "ndmi_wet = ls_wet.normalizedDifference(['SR_B5','SR_B6']).rename('NDMI_wet')\n",
        "ndmi_diff = ndmi_wet.subtract(ndmi_dry).rename('ndmi_diff')\n",
        "\n",
        "# ==========================\n",
        "# 5. แสดงผลบน Map\n",
        "# ==========================\n",
        "Map.addLayer(ndvi_dry, {'min':0,'max':0.8,'palette':['red','yellow','green']}, 'Landsat NDVI Dry')\n",
        "Map.addLayer(ndvi_wet, {'min':0,'max':0.8,'palette':['red','yellow','green']}, 'Landsat NDVI Wet')\n",
        "Map.addLayer(ndvi_diff, {'min':-0.3,'max':0.3,'palette':['brown','yellow','green']}, 'NDVI Diff')\n",
        "\n",
        "Map.addLayer(ndmi_dry, {'min':-0.2,'max':0.4,'palette':['#d73027','#f4a582','#f7f7f7','#92c5de','#0571b0']}, 'NDMI Dry')\n",
        "Map.addLayer(ndmi_wet, {'min':-0.2,'max':0.4,'palette':['#d73027','#f4a582','#f7f7f7','#92c5de','#0571b0']}, 'NDMI Wet')\n",
        "Map.addLayer(ndmi_diff, {'min':-0.2,'max':0.2,'palette':['red','white','blue']}, 'NDMI Change')\n",
        "\n",
        "Map.addLayerControl()\n",
        "Map\n"
      ],
